generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Game {
  steamId    Int         @id
  name       String      @unique
  blacklists Blacklist[]

  @@map("games")
}

model User {
  discordId  Int         @id
  steamId    Int         @unique
  blacklists Blacklist[]

  @@map("users")
}

model Blacklist {
  id            Int  @id @default(autoincrement())
  user          User @relation(fields: [userDiscordId], references: [discordId])
  userDiscordId Int
  game          Game @relation(fields: [gameSteamId], references: [steamId])
  gameSteamId   Int

  @@map("blacklists")
}
